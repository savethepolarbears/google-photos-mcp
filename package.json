{
  "name": "google-photos-mcp",
  "version": "0.1.0",
  "description": "MCP server for Google Photos integration with Claude",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "stdio": "node dist/index.js --stdio",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:security": "vitest run test/security/",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix"
  },
  "keywords": [
    "mcp",
    "google-photos",
    "claude",
    "anthropic"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "google-auth-library": "^9.15.1",
    "googleapis": "^144.0.0",
    "keytar": "^7.9.0",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.4",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.0.6",
    "eslint": "^9.21.0",
    "markdownlint-cli2": "^0.17.2",
    "prettier": "^3.5.1",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "vitest": "^3.0.6"
  }
}
